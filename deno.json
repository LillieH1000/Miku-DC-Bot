{
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "esnext"
    ],
    "module": "esnext",
    "strict": true
  },
  "imports": {
    "@date-fns/tz": "npm:@date-fns/tz@^1.5.0",
    "date-fns": "npm:date-fns@^4.4.0",
    "discord.js": "npm:discord.js@^14.26.4",
    "lz-string": "npm:lz-string@^1.5.0"
  },
  "lint": {
    "rules": {
      "include": [
        "eqeqeq"
      ],
      "tags": [
        "recommended"
      ]
    }
  },
  "permissions": {
    "default": {
      "env": true,
      "ffi": true,
      "net": [
        "*.discord.com",
        "*.discord.gg",
        "*.pokeapi.co",
        "*.returnyoutubedislikeapi.com"
      ],
      "read": [
        "commands",
        "globals",
        "utils",
        "/etc/alpine-release",
        "/proc/self/exe",
        "/usr/bin/ldd"
      ],
      "sys": [
        "cpus",
        "hostname",
        "networkInterfaces"
      ]
    },
    "register": {
      "env": true,
      "ffi": true,
      "net": [
        "*.discord.com"
      ],
      "read": [
        "commands",
        "/etc/alpine-release",
        "/usr/bin/ldd"
      ]
    }
  }
}